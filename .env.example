APP_NAME="LEGADO AB FENIX"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Mexico_City
APP_LOCALE=es

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=legado_ab_fenix
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

AI_ENABLED=false
AI_PROVIDER=gemini
AI_API_KEY=your_ai_api_key_here
AI_MODEL=gemini-3.5-flash
AI_EMBEDDING_MODEL=gemini-embedding-2
AI_BASE_URL=https://api.openai.com/v1
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_TIMEOUT=90
AI_MAX_RETRIES=2
AI_QUEUE=default
AI_MAX_PLANS_PER_EVENT=1
AI_MAX_CONTEXT_CHARS=18000
AI_MAX_KNOWLEDGE_CHUNKS=6
AI_PROMPT_VERSION=washer-action-plan-v1
AI_KNOWLEDGE_CHUNK_SIZE=1200
AI_KNOWLEDGE_CHUNK_OVERLAP=200
AI_KNOWLEDGE_PDF_OCR_ENABLED=true
AI_KNOWLEDGE_PDF_OCR_DETAIL=high
AI_KNOWLEDGE_PDF_OCR_MODEL=

WASHER_ELONGACION_WARNING_THRESHOLD=1.30
WASHER_ELONGACION_CRITICAL_THRESHOLD=1.46
WASHER_ELONGACION_TREND_MIN_DELTA=0.05
WASHER_RODAJA_MAX_MM=
WASHER_HIGH_COST_THRESHOLD=0
WASHER_COST_GROWTH_RATIO=1.25
